# Sprout reads ONE secret: the Postgres connection string.
#
# You do NOT fill this in by hand for the demo. Instead:
#   vercel integration add neon   # provisions Neon + sets DATABASE_URL on Vercel
#   vercel env pull               # writes the real value into .env.local
#
# Local-only manual option (e.g. a Neon free DB): copy this file to .env.local
# and paste your connection string below.
DATABASE_URL=
