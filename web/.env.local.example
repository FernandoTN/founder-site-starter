# Copy to .env.local for local dev. In production these are injected by Vercel
# (DATABASE_URL by the Neon integration) and pulled with `vercel env pull`.
# Never commit the real .env.local.

# Neon Postgres connection string (from `vercel integration add neon`)
DATABASE_URL=

# The single owner passcode that unlocks /admin
ADMIN_PASSCODE=let-me-in

# Opaque session-cookie value the middleware checks (set to any long random string)
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
